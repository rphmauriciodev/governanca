# Database Configuration
DATABASE_URL=mysql://seu_usuario:sua_sennha@host:3306/database_name

# Node Environment
NODE_ENV=production

# OAuth Configuration (Google)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/callback

# AWS S3 Configuration (for file uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=your_bucket_name

# LLM Configuration
# Para OpenAI: use api.openai.com
# Para Gemini: use https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_API_KEY=AIzaSyBASG2S0km12oXmaR4jPMEc7Cq2RTVCOpc
OPENAI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-1.5-flash

# Application URLs
VITE_API_URL=https://your-domain.com
VITE_APP_URL=https://your-domain.com

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@your-domain.com

# Google Maps API (if using maps)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Logging
LOG_LEVEL=info
